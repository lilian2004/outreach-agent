# --- LLM ---
# Provider: "groq" (free, no credit card) or "anthropic" (paid).
LLM_PROVIDER=groq

# Groq (free): get a key at https://console.groq.com  (no card required)
GROQ_API_KEY=gsk_xxxxx
# Optional model override (Groq default: llama-3.3-70b-versatile)
LLM_MODEL=llama-3.3-70b-versatile

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Email ---
# For Gmail, create an App Password (not your normal password):
# Google Account -> Security -> 2-Step Verification -> App passwords
EMAIL_ADDRESS=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SENDER_NAME=Lilian Miceli
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com

# --- Your assets (injected into every email) ---
PORTFOLIO_URL=https://your-portfolio-url

# --- Sending safety ---
DAILY_SEND_LIMIT=15
FOLLOWUP_1_DAYS=4
FOLLOWUP_2_DAYS=10
DB_PATH=outreach.db
